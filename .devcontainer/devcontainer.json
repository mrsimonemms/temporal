{
  "name": "devcontainer",
  "image": "ghcr.io/mrsimonemms/devcontainers/full",
  "features": {
    "ghcr.io/mrsimonemms/devcontainers/cobra-cli:0": {},
    "ghcr.io/guiyomh/features/goreleaser:0": {},
    "ghcr.io/devcontainers-extra/features/temporal-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.makefile-tools",
        "golang.go",
        "cweijan.vscode-mysql-client2"
      ],
      "settings": {}
    }
  },
  "postCreateCommand": {
    "bootstrap": "ln -s $PWD/.cobra.yaml $HOME/.cobra.yaml && if [ ! -f \"go.mod\" ]; then go mod init \"github.com/mrsimonemms/temporal\"; fi && if [ ! -f \"main.go\" ]; then cobra-cli init && go mod tidy; fi"
  },
  "containerEnv": {
    "GIT_REPO": "github.com/mrsimonemms/temporal"
  }
}
